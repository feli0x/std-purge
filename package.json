{
  "name": "std-purge",
  "version": "0.1.0",
  "description": "A CLI for aggressively cleaning Shopify theme JSON templates and settings.",
  "type": "module",
  "bin": {
    "std-purge": "./dist/cli.js"
  },
  "scripts": {
